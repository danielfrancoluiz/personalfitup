# ============================================================
# Personal Fit Up — variáveis de ambiente
# Copie para .env (local) ou configure na Vercel por ambiente:
#   Production  → branch main  (PRD)
#   Preview     → branch dev   (DEV / testes)
#   Development → vercel env pull / vercel dev
# Hoje os 3 apontam para o mesmo Supabase de teste.
# Depois: Preview/Development → projeto Supabase separado (DEV).
# ============================================================

# Supabase (obrigatório)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Alias usado pelas API routes (pode ser igual à VITE_SUPABASE_URL)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Supabase service role — APENAS server/scripts (nunca no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Stripe — chave pública (opcional; também pode vir do Financeiro > Stripe no app)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe (API serverless — checkout e webhook)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Base44 — somente para exportar dados antigos (script migrate:from-base44)
BASE44_APP_ID=69ea31515b70bc9ef16762b9
BASE44_APP_BASE_URL=https://SEU_APP.base44.app

# URL pública do app — webhooks Stripe / links
# PRD: https://personalfitup.com.br
# DEV: URL do preview da Vercel (*.vercel.app) ou domínio dev
VITE_APP_URL=https://personalfitup.com.br
